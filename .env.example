# RouteStack MCP Server
ROUTESTACK_API_KEY=your_api_key_here
ROUTESTACK_API_SECRET=your_api_key_secret_here
ROUTESTACK_MCP_URL=https://mcp.routestack.ai/sse

# LLM Provider "openai", "anthropic", or "mistral" (choose one)
LLM_PROVIDER=mistral

MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

